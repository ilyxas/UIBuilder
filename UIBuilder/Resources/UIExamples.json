  {
    "schema": "com.ilya.ui/1.0",
    "screenId": "group-collapsible",
    "title": "Group Example",
    "state": {
      "vars": {
        "notificationsOn": true,
        "darkMode": false,
        "devMode": false
      }
    },
    "root": {
      "type": "vstack",
      "props": {
        "spacing": 16,
        "padding": 20
