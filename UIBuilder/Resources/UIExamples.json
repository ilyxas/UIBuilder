  {
    "schema": "com.ilya.ui/1.0",
    "screenId": "webview-demo",
    "title": "WebView Demo",
    "state": { "vars": {} },
    "root": {
      "type": "vstack",
      "props": { "spacing": 12, "padding": 16 },
      "children": [
        {
          "type": "webview",
          "id": "browser",
          "props": {
            "url": "https://example.com",
            "height": 400,
            "cornerRadius": 12
          }
        },
        {
          "type": "hstack",
          "props": { "spacing": 8 },
          "children": [
            {
              "type": "button",
              "props": { "label": "Red", "backgroundColor": "#E74C3C", "foregroundColor": "#FFFFFF", "cornerRadius": 8, "padding": 10 },
              "event": { "tap": "makeRed" }
            },
            {
              "type": "button",
              "props": { "label": "Blue", "backgroundColor": "#2980B9", "foregroundColor": "#FFFFFF", "cornerRadius": 8, "padding": 10 },
              "event": { "tap": "makeBlue" }
            },
            {
              "type": "button",
              "props": { "label": "Reset", "backgroundColor": "#95A5A6", "foregroundColor": "#FFFFFF", "cornerRadius": 8, "padding": 10 },
              "event": { "tap": "resetBg" }
            }
          ]
        }
      ]
    },
    "events": {
      "makeRed": [
        { "do": "eval", "target": "browser", "script": "document.body.style.backgroundColor = 'red';" }
      ],
      "makeBlue": [
        { "do": "eval", "target": "browser", "script": "document.body.style.backgroundColor = 'blue';" }
      ],
      "resetBg": [
        { "do": "eval", "target": "browser", "script": "document.body.style.backgroundColor = '';" }
      ]
    },
    "meta": { "version": 1, "author": "UIBuilder", "tags": ["webview", "eval", "javascript"] }
  },
  {
    "schema": "com.ilya.ui/1.0",
    "screenId": "browser-screen",
    "title": "Browser Screen",
    "notes": "Correct pattern for a browser-like screen. Root is vstack(spacing:0) — NOT navigationstack, which would add an unwanted large title area. The webview fills all available space. All interactions with the page (navigation, overlays, search) go through eval targeting the webview id. JS runs in the webview context and cannot read SwiftUI state — the urlInput textfield writes to state on each keystroke but that value is not accessible inside eval scripts. The Go button is a stub until webview.load action is implemented natively.",
    "state": {
      "vars": {
        "urlInput": ""
      }
    },
    "root": {
      "type": "vstack",
      "props": { "spacing": 0 },
      "children": [
        {
          "type": "hstack",
          "props": { "spacing": 8, "padding": 8 },
          "children": [
            {
              "type": "textfield",
              "props": {
                "bind": "urlInput",
                "placeholder": "https://",
                "keyboardType": "url",
                "returnKeyType": "go",
                "autocorrectionDisabled": true,
                "autocapitalization": "none",
                "backgroundColor": "#F2F2F7",
                "cornerRadius": 10,
                "padding": 10
              }
            },
            {
              "type": "button",
              "props": {
                "label": "Go",
                "backgroundColor": "#2563EB",
                "foregroundColor": "#FFFFFF",
                "cornerRadius": 10,
                "padding": 10
              },
              "event": { "tap": "goPressed" }
            }
          ]
        },
        {
          "type": "webview",
          "id": "wb",
          "props": {
            "url": "https://example.com",
            "maxHeight": "infinity",
            "maxWidth": "infinity"
          }
        },
        {
          "type": "hstack",
          "props": { "spacing": 0, "padding": 8, "backgroundColor": "#F2F2F7" },
          "children": [
            {
              "type": "button",
              "props": { "label": "‹", "foregroundColor": "#2563EB", "padding": 12 },
              "event": { "tap": "goBack" }
            },
            {
              "type": "button",
              "props": { "label": "›", "foregroundColor": "#2563EB", "padding": 12 },
              "event": { "tap": "goForward" }
            },
            { "type": "spacer" },
            {
              "type": "button",
              "props": { "label": "⌂", "foregroundColor": "#2563EB", "padding": 12 },
              "event": { "tap": "goHome" }
            },
            { "type": "spacer" },
            {
              "type": "menu",
              "props": { "title": "More", "icon": "ellipsis.circle" },
              "children": [
                {
                  "type": "button",
                  "props": { "label": "Translate to Russian", "icon": "globe" },
                  "event": { "tap": "translatePage" }
                },
                {
                  "type": "button",
                  "props": { "label": "Find Chat", "icon": "bubble.left" },
                  "event": { "tap": "findChat" }
                },
                {
                  "type": "button",
                  "props": { "label": "Toggle Stats", "icon": "chart.bar" },
                  "event": { "tap": "toggleStats" }
                }
              ]
            }
          ]
        }
      ]
    },
    "events": {
      "goPressed": [
        {
          "do": "eval",
          "target": "wb",
