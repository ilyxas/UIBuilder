  {
    "schema": "com.ilya.ui/1.0",
    "screenId": "navigationstack-list-toolbar",
    "title": "NavigationStack with Toolbar",
    "state": {
      "vars": {}
    },
    "root": {
      "type": "navigationstack",
      "props": {
        "title": "My Screen"
      },
      "host": {
        "toolbar": {
          "topTrailing": [
            {
              "type": "button",
              "props": {
                "label": "Add",
                "icon": "plus"
              },
              "event": {
                "tap": "addPressed"
              }
            }
          ]
        }
      },
      "children": [
        {
          "type": "list",
          "children": [
            {
              "type": "section",
              "props": {
                "title": "Account"
              },
              "children": [
                {
                  "type": "label",
                  "props": {
                    "title": "Profile",
                    "icon": "person.circle"
                  }
                },
                {
                  "type": "label",
                  "props": {
                    "title": "Notifications",
                    "icon": "bell"
                  }
                }
              ]
            },
            {
              "type": "section",
              "props": {
                "title": "Support"
              },
              "children": [
                {
                  "type": "label",
                  "props": {
                    "title": "Help",
                    "icon": "questionmark.circle"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    "events": {
      "addPressed": [
        {
          "do": "ui.toast",
          "message": "Add pressed"
        }
      ]
    }
  },
  {
    "schema": "com.ilya.ui/1.0",
    "screenId": "list-section-toggle",
    "title": "List + Section Example",
    "state": {
      "vars": {
        "darkMode": false,
        "notificationsEnabled": true
      }
    },
    "root": {
      "type": "list",
      "children": [
