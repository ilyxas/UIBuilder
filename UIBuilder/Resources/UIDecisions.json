{\n  "decisions": {\n    "vstack": {\n      "useWhen": [\n        "Stacking content vertically with consistent spacing",\n        "Building form layouts",\n        "Composing a screen body with multiple sections"\n      ],\n      "avoidWhen": [\n        "Content is scrollable — wrap in scroll instead",\n        "Horizontal layout is needed — use hstack"\n      ],\n      "preferOver": ["zstack", "frame"]\n    },\n    "hstack": {\n      "useWhen": [\n        "Placing elements side by side in a row",\n        "Building toolbar-like rows with a spacer",\n        "Label + value pairs on the same line"\n      ],\n      "avoidWhen": [\n        "Content needs to wrap to multiple lines",\n        "Vertical layout is needed — use vstack"\n      ]\n    },\n    "zstack": {\n      "useWhen": [\n        "Overlaying content on top of a background shape or image",\n        "Placing a badge or overlay on top of another node"\n      ],\n      "avoidWhen": [\n        "Nodes need explicit alignment with frame constraints — use frame",\n        "Vertical or horizontal flow layout is needed"\n      ],\n      "preferOver": ["frame"]\n    },\n    "scroll": {\n      "useWhen": [\n        "Content may exceed the visible screen area",\n        "Horizontal scrolling chip rows or card carousels",\n        "Any screen that is not a List"\n      ],\n      "avoidWhen": [\n        "Content is guaranteed to fit on screen",\n        "A native document list with sections is needed — use list",\n        "Wrapping a list node — list is already scrollable and scroll will collapse it to zero height"\n      ]\n    },\n    "text": {\n      "useWhen": [\n        "Displaying a static or state-bound string",\n        "Rendering a formatted template with multiple bound values"\n      ],\n      "avoidWhen": [\n        "An icon is also needed alongside the text — use label",\n        "The text should be editable — use textfield"\n      ],\n      "preferOver": ["badge"]\n    },\n    "button": {\n      "useWhen": [\n        "A tappable action is required",\n        "Confirming, submitting, or triggering any event"\n      ],\n      "avoidWhen": [\n        "A boolean on/off control is needed — use toggle",\n        "The tap should navigate — use nav.push action inside button"\n      ]\n    },\n    "toggle": {\n      "useWhen": [\n        "A boolean on/off switch bound to a state variable",\n        "Settings rows with an enable/disable control"\n      ],\n      "avoidWhen": [\n        "Multiple exclusive options are needed — use a different pattern",\n        "The value is not boolean"\n      ]\n    },\n    "icon": {\n      "useWhen": [\n        "A standalone SF Symbol icon with explicit size is needed",\n        "Decorative icon with no accompanying text"\n      ],\n      "avoidWhen": [\n        "An icon paired with a text label is needed — use label",\n        "The icon is part of a button — use button with icon prop"\n      ],\n      "preferOver": []\n    },\n    "spacer": {\n      "useWhen": [\n        "Pushing sibling elements to opposite ends of an hstack or vstack",\n        "Creating flexible empty space between nodes"\n      ],\n      "avoidWhen": [\n        "Fixed spacing between elements is needed — use the spacing prop on the parent stack"\n      ]\n    },\n    "badge": {\n      "useWhen": [\n        "Displaying a small highlighted count or tag",\n        "Status chips with a pill/capsule background"\n      ],\n      "avoidWhen": [\n        "Plain text display is needed — use text",\n        "Custom styling is required — badge has fixed inline styling"\n      ]\n    },\n    "label": {\n      "useWhen": [\n        "Displaying an SF Symbol icon paired with a text title",\n        "Settings rows, menu items, or list rows with an icon"\n      ],\n      "avoidWhen": [\n        "No icon is needed — use text",\n        "The icon and text need independent styling — use hstack with icon and text nodes"\n      ],\n      "preferOver": ["hstack"]\n    },\n    "menu": {\n      "useWhen": [\n        "A dropdown menu with multiple contextual actions is needed",\n        "Toolbar or list row with an ellipsis/more button"\n      ],\n      "avoidWhen": [\n        "Only one action is available — use button",\n        "Actions should always be visible — use buttons in an hstack"\n      ]\n    },\n    "tabview": {\n      "useWhen": [\n        "Top-level navigation between two or more major screens",\n        "App-level tab bar at the bottom of the screen"\n      ],\n      "avoidWhen": [\n        "Segmented in-screen switching — use state + visibleWhen pattern instead",\n        "Only one screen exists"\n      ],\n      "note": "tabview must be the root child of the screen document. Each tab that needs push navigation must contain its own navigationstack as the tab's root child — do NOT wrap the entire tabview in a navigationstack."\n    },\n    "tab": {\n      "useWhen": [\n        "As a direct child of tabview to define a tab's content and tab bar item",\n        "When the tab needs a navigation bar, place a navigationstack as the tab's first child"\n      ],\n      "avoidWhen": [\n        "Outside of a tabview — it renders as a plain vstack with no tab bar item"\n      ]\n    },\n    "image": {\n      "useWhen": [\n        "Displaying an SF Symbol as a resizable image",\n        "Displaying an asset catalog image by name"\n      ],\n      "avoidWhen": [\n        "A small inline icon is needed — use icon or label",\n        "No actual image source is known — a placeholder will appear"\n      ]\n    },\n    "navigationstack": {\n      "useWhen": [\n        "The screen needs a navigation bar with a title",\n        "Toolbar buttons in topLeading, topTrailing, principal, or bottomBar slots are needed",\n        "The screen is the root of a push-navigation flow",\n        "A tab inside a tabview needs its own navigation bar — place navigationstack as the tab's root child"\n      ],\n      "avoidWhen": [\n        "No navigation bar or toolbar is needed — use vstack or scroll",\n        "The screen is already inside a navigationstack",\n        "The screen root is a tabview — navigationstack must not wrap tabview; place it inside each tab instead"\n      ]\n    },\n    "list": {\n      "useWhen": [\n        "A native document-style grouped or plain list with section support",\n        "Settings screens with multiple sections and rows"\n      ],\n      "avoidWhen": [\n        "Custom row spacing or background is needed — use vstack in scroll",\n        "Horizontal layout is needed",\n        "Wrapping inside a scroll node — list manages its own scrolling; wrapping it in scroll collapses it to zero height"\n      ],\n      "preferOver": ["vstack"]\n    },\n    "section": {\n      "useWhen": [\n        "Grouping rows inside a list with an optional header title"\n      ],\n      "avoidWhen": [\n        "Outside of a list — use group instead for card or plain grouping"\n      ],\n      "preferOver": ["group"]\n    },\n    "frame": {\n      "useWhen": [\n        "Applying explicit alignment (e.g. bottomTrailing) to children within fixed dimensions",\n        "Clipping children to a specific size with clip or clipShape"\n      ],\n      "avoidWhen": [\n        "Simple overlay without alignment constraints — use zstack",\n        "No fixed dimensions are needed"\n      ]\n    },\n    "textfield": {\n      "useWhen": [\n        "Single-line text input bound to a state variable",\n        "Search fields, name fields, email fields, password fields"\n      ],\n      "avoidWhen": [\n        "Multi-line input is needed — not currently supported",\n        "Value is not a string"\n      ]\n    },\n    "slider": {\n      "useWhen": [\n        "Continuous or stepped numeric value selection bound to a state variable",\n        "Volume controls, ratings, progress adjustments"\n      ],\n      "avoidWhen": [\n        "A discrete set of options is needed — use buttons or a different pattern",\n        "The value is not numeric"\n      ]\n    },\n    "shape": {\n      "useWhen": [\n        "Drawing a geometric shape (circle, rectangle, capsule, ellipse, roundedRectangle)",\n        "Using a shape as a colored background block or decorative divider",\n        "Overlaying child nodes on top of a shape via its children array"\n      ],\n      "avoidWhen": [\n        "Background color on an existing node is sufficient — use backgroundColor common prop",\n        "Clipping a container to a shape — use clipShape common prop"\n      ]\n    },\n    "group": {\n      "useWhen": [\n        "Grouping related content outside of a list with an optional title and footer",\n        "Collapsible sections with a disclosure toggle",\n        "Card-style or inset-style content blocks"\n      ],\n      "avoidWhen": [\n        "Content is inside a list — use section instead",\n        "No visual grouping is needed — use vstack"\n      ],\n      "preferOver": ["section"]\n    },\n    "table": {\n      "useWhen": [\n        "Displaying tabular data with named columns and a header row",\n        "Alternating row backgrounds for readability",\n        "Single-row selection from a data set"\n      ],\n      "avoidWhen": [\n        "Rows have heterogeneous layouts — use list with custom children",\n        "No columns or header is needed — use list"\n      ],\n      "preferOver": ["list"]\n    }\n  }\n}