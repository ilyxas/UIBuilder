{
  "version": 2,
  "status": "base-stable-strict",
  "engine": {
    "name": "UIBuilder Base Runtime",
    "authoringMode": "base-json",
    "notes": [
      "This file is a strict generation contract for the current base runtime.",
      "Use native SwiftUI-like composition.",
      "Do not invent unsupported node types or event formats."
    ]
  },
  "documents": {
    "screenDocument": {
      "requiredFields": ["schema", "screenId", "root", "events"],
      "optionalFields": ["title", "theme", "state", "meta"]
    },
    "uiNode": {
      "requiredFields": ["type"],
      "optionalFields": [
        "id",
        "props",
        "children",
        "visibleWhen",
        "enabledWhen",
        "event",
        "items"
      ],
      "notes": [
        "Children are rendered recursively.",
        "Renderer must not invent subtree structure."
      ]
    }
  },
  "nodeTypes": {
    "layout": ["vstack", "hstack", "zstack", "scroll", "spacer"],
    "primitive": ["text", "icon", "toggle", "badge", "label"],
    "composite": ["button", "menu", "tabview", "tab"]
  },
  "nodeRules": {
    "vstack": {
      "childrenAllowed": true
    },
    "hstack": {
      "childrenAllowed": true
    },
    "zstack": {
      "childrenAllowed": true
    },
    "scroll": {
      "childrenAllowed": true
    },
    "spacer": {
      "childrenAllowed": false
    },
    "text": {
      "childrenAllowed": false,
      "requiredProps": ["value"]
    },
    "icon": {
      "childrenAllowed": false,
      "requiredProps": ["name"],
      "optionalProps": ["size"]
    },
    "toggle": {
      "childrenAllowed": false,
      "requiredProps": ["title", "bind"]
    },
    "badge": {
      "childrenAllowed": false
    },
    "button": {
      "childrenAllowed": true,
      "childrenRecommended": true,
      "requiredEventKeys": ["tap"],
      "notes": [
        "Button is a composite node.",
        "Button label must be authored through children in base mode.",
        "Renderer must not auto-create text or icon subtree from props."
      ]
    },
    "label": {
      "childrenAllowed": false,
      "requiredProps": ["title"],
      "optionalProps": ["icon"],
      "notes": [
        "Semantic node combining icon + text in one unit.",
        "icon must be a valid SF Symbol name.",
        "Use instead of manually composing hstack with icon and text."
      ]
    },
    "menu": {
      "childrenAllowed": true,
      "childrenRecommended": true,
      "optionalProps": ["title", "icon"],
      "notes": [
        "Composite node. Children are menu items (buttons or other interactive nodes).",
        "A child with id='label' or type='label' will be used as the menu trigger label.",
        "If no label child is provided, props title and icon are used to build the trigger.",
        "Renderer must not auto-create label from props if a label child is present."
      ]
    },
    "tabview": {
      "childrenAllowed": true,
      "childrenRecommended": true,
      "optionalProps": ["selection"],
      "notes": [
        "Semantic TabView. Children must be of type 'tab'.",
        "selection prop is a string key bound to state for programmatic tab switching.",
        "Tab identifiers (id) are used as selection tags when selection is active."
      ]
    },
    "tab": {
      "childrenAllowed": true,
      "requiredProps": ["title"],
      "optionalProps": ["icon"],
      "notes": [
        "Must be a direct child of tabview.",
        "title and icon props define the .tabItem label.",
        "icon must be a valid SF Symbol name.",
        "children define the content rendered inside the tab."
      ]
    }
  },
  "props": {
    "common": [
      "backgroundColor",
      "foregroundColor",
      "opacity"
    ],
    "layout": ["spacing", "alignment"],
    "text": ["value"],
    "icon": ["name", "size"],
    "toggle": ["title", "bind"]
  },
  "strictFormats": {
    "nodeEventFormat": {
      "description": "Node event values must be string event names.",
      "valid": {
        "event": {
          "tap": "searchPressed"
        }
      },
      "invalid": [
        {
          "event": {
            "tap": [
              {
                "do": "state.set",
                "key": "statusText",
                "value": "Search pressed"
              }
            ]
          }
        }
      ]
    },
    "topLevelEventsFormat": {
      "description": "All actions live in top-level events map.",
      "valid": {
        "events": {
          "searchPressed": [
            {
              "do": "state.set",
              "key": "statusText",
              "value": "Search pressed"
            }
          ]
        }
      }
    },
    "actionFormat": {
      "requiredFields": ["do"],
      "optionalFields": ["key", "value", "min", "max", "id", "input", "message"],
      "disallowedAliases": ["action", "target"]
    },
    "textValueFormat": {
      "allowedForms": [
        { "value": "Literal text" },
        { "value": { "bind": "selectedField" } },
        { "value": { "format": "Count: {count}", "binds": ["count"] } }
      ],
      "disallowedForms": [
        { "value": "$state.selectedField" }
      ]
    }
  },
  "actions": {
    "supported": [
      "state.set",
      "state.inc",
      "state.dec",
      "state.toggle",
      "ui.toast",
      "ai.request"
    ]
  },
  "expressions": {
    "supportedContexts": ["visibleWhen", "enabledWhen"]
  },
  "baseModeConstraints": {
    "disallowedNodeTypes": ["frame", "box", "columns", "toolbar"],
    "notes": [
      "Do not generate these node types for base runtime documents."
    ]
  },
  "ownershipBoundaries": {
    "appOwns": [
      "shell",
      "safe area handling",
      "device-aware layout policy",
      "top and bottom overlay policy",
      "screen bounds awareness"
    ],
    "jsonOwns": [
      "content tree",
      "local node composition",
      "local props",
      "state bindings",
      "event wiring",
      "section structure"
    ]
  },
  "generationRules": [
    "Use only supported node types.",
    "Use button as composite node with children.",
    "Do not inline actions inside node.event.",
    "Do not invent aliases for action fields.",
    "Do not use unsupported dynamic text syntaxes.",
    "Prefer native stack composition.",
    "Prefer local props over artificial wrapper nodes.",
    "Do not generate deprecated or experimental layout abstractions in base mode."
  ],
  "knownProjectFacts": {
    "layoutSupportUsed": false,
    "documentValidatorActive": false,
    "buttonCompositeModeActive": true
  },
  "nodeExamples": {
    "label": {
      "description": "Semantic icon + text в одной ноде.",
      "example": {
        "type": "label",
        "props": {
          "title": "Настройки",
          "icon": "gearshape",
          "foregroundColor": "#333333"
        }
      }
    },
    "menu": {
      "description": "Контекстное меню с trigger-лейблом и пунктами из children.",
      "example": {
        "type": "menu",
        "props": {
          "title": "Действия",
          "icon": "ellipsis.circle"
        },
        "children": [
          {
            "type": "button",
            "event": { "tap": "editPressed" },
            "children": [
              { "type": "label", "props": { "title": "Редактировать", "icon": "pencil" } }
            ]
          },
          {
            "type": "button",
            "event": { "tap": "deletePressed" },
            "children": [
              { "type": "label", "props": { "title": "Удалить", "icon": "trash" } }
            ]
          }
        ]
      }
    },
    "tabview": {
      "description": "TabView с двумя табами. selection привязан к state.",
      "example": {
        "type": "tabview",
        "props": { "selection": "activeTab" },
        "children": [
          {
            "type": "tab",
            "id": "home",
            "props": { "title": "Главная", "icon": "house" },
            "children": [
              { "type": "text", "props": { "value": "Экран главной" } }
            ]
          },
          {
            "type": "tab",
            "id": "settings",
            "props": { "title": "Настройки", "icon": "gearshape" },
            "children": [
              { "type": "text", "props": { "value": "Экран настроек" } }
            ]
          }
        ]
      }
    }
  }
}
