{
  "schema": "com.ilya.ui/1.0",
  "screenId": "example-button-composite",
  "root": {
    "type": "vstack",
    "id": "rootStack",
    "props": {
      "spacing": 12,
      "padding": 16,
      "maxWidth": "infinity"
    },
    "children": [
      {
        "type": "button",
        "id": "homeButton",
        "props": {
          "padding": 12,
          "backgroundColor": "#EEF2FF",
          "foregroundColor": "#2563EB",
          "cornerRadius": 12,
          "maxWidth": "infinity"
        },
        "event": {
          "tap": "homePressed"
        },
        "children": [
          {
            "type": "hstack",
            "id": "homeButtonLabel",
            "props": {
              "spacing": 8,
              "alignment": "center",
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "icon",
                "id": "homeButtonIcon",
                "props": {
                  "name": "house.fill",
                  "size": 18
                }
              },
              {
                "type": "text",
                "id": "homeButtonText",
                "props": {
                  "value": "Home"
                }
              },
              {
                "type": "spacer",
                "id": "homeButtonSpacer"
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "homePressed": [
      {
        "do": "ui.toast",
        "message": "Home pressed"
      }
    ]
  }
}

{
  "schema": "com.ilya.ui/1.0",
  "screenId": "example-settings-row",
  "root": {
    "type": "vstack",
    "id": "rootStack",
    "props": {
      "spacing": 0,
      "padding": 16,
      "maxWidth": "infinity",
      "backgroundColor": "#FFFFFF",
      "cornerRadius": 16
    },
    "children": [
      {
        "type": "button",
        "id": "privacyRow",
        "props": {
          "padding": 14,
          "foregroundColor": "#111111",
          "maxWidth": "infinity"
        },
        "event": {
          "tap": "privacyPressed"
        },
        "children": [
          {
            "type": "hstack",
            "id": "privacyRowContent",
            "props": {
              "spacing": 12,
              "alignment": "center",
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "icon",
                "id": "privacyRowIcon",
                "props": {
                  "name": "lock",
                  "size": 18
                }
              },
              {
                "type": "text",
                "id": "privacyRowText",
                "props": {
                  "value": "Конфиденциальность"
                }
              },
              {
                "type": "spacer",
                "id": "privacyRowSpacer"
              },
              {
                "type": "icon",
                "id": "privacyRowChevron",
                "props": {
                  "name": "chevron.right",
                  "size": 14,
                  "foregroundColor": "#C7C7CC"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "privacyPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Privacy selected"
      }
    ]
  }
}

{
  "schema": "com.ilya.ui/1.0",
  "screenId": "example-small-screen",
  "title": "Controls",
  "state": {
    "vars": {
      "selectedField": "Ничего не выбрано",
      "wifiEnabled": false
    }
  },
  "root": {
    "type": "scroll",
    "id": "rootScroll",
    "children": [
      {
        "type": "vstack",
        "id": "rootStack",
        "props": {
          "spacing": 16,
          "padding": 16,
          "maxWidth": "infinity"
        },
        "children": [
          {
            "type": "hstack",
            "id": "topButtons",
            "props": {
              "spacing": 12,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "button",
                "id": "homeButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "homePressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "homeIcon",
                    "props": {
                      "name": "house",
                      "size": 18
                    }
                  }
                ]
              },
              {
                "type": "button",
                "id": "searchButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "searchPressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "searchIcon",
                    "props": {
                      "name": "magnifyingglass",
                      "size": 18
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "hstack",
            "id": "wifiRow",
            "props": {
              "spacing": 12,
              "padding": 12,
              "backgroundColor": "#FFFFFF",
              "cornerRadius": 12,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "button",
                "id": "wifiRowButton",
                "props": {
                  "maxWidth": "infinity"
                },
                "event": {
                  "tap": "wifiPressed"
                },
                "children": [
                  {
                    "type": "hstack",
                    "id": "wifiRowLabel",
                    "props": {
                      "maxWidth": "infinity"
                    },
                    "children": [
                      {
                        "type": "text",
                        "id": "wifiRowText",
                        "props": {
                          "value": "Wi-Fi"
                        }
                      },
                      {
                        "type": "spacer",
                        "id": "wifiRowSpacer"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "toggle",
                "id": "wifiToggle",
                "props": {
                  "title": "",
                  "bind": "wifiEnabled"
                },
                "event": {
                  "change": "wifiChanged"
                }
              }
            ]
          },
          {
            "type": "card",
            "id": "bottomCard",
            "props": {
              "padding": 16,
              "backgroundColor": "#F2F2F7",
              "cornerRadius": 16,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "vstack",
                "id": "bottomCardStack",
                "props": {
                  "spacing": 8,
                  "alignment": "leading",
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "text",
                    "id": "bottomCardTitle",
                    "props": {
                      "value": "Поле внизу"
                    }
                  },
                  {
                    "type": "text",
                    "id": "bottomCardValue",
                    "props": {
                      "value": {
                        "bind": "selectedField"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "homePressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Home pressed"
      }
    ],
    "searchPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Search pressed"
      }
    ],
    "wifiPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Wi-Fi row selected"
      }
    ],
    "wifiChanged": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Wi-Fi changed"
      }
    ]
  },
  "meta": {
    "examplePurpose": "small canonical screen",
    "rulesShown": [
      "button as composite",
      "row composition",
      "toggle row",
      "top-level events map",
      "bind-based text value"
    ]
  }
}

{
    "Task" :
        "Используй только этот протокол и только этот wire format.
        Собери новый ScreenDocument:
        - сверху горизонтальный ряд из 4 иконок-кнопок
        - ниже список из 4 строк
        - в каждой строке слева нажимаемая текстовая часть, справа toggle
        - внизу карточка, которая показывает выбранное поле
        - button должен быть composite node с children
        - event у node должен содержать только строковое имя события
        - все действия должны жить только в top-level events
        - не использовать frame, box, columns, toolbar
        - не использовать inline actions inside event
        - не использовать $state.something

        Выдай только JSON."
}
