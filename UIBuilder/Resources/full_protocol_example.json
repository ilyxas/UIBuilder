capabilities.json
{
  "version": 2,
  "status": "base-stable-strict",
  "engine": {
    "name": "UIBuilder Base Runtime",
    "authoringMode": "base-json",
    "notes": [
      "This file is a strict generation contract for the current base runtime.",
      "Use native SwiftUI-like composition.",
      "Do not invent unsupported node types or event formats."
    ]
  },
  "documents": {
    "screenDocument": {
      "requiredFields": ["schema", "screenId", "root", "events"],
      "optionalFields": ["title", "theme", "state", "meta"]
    },
    "uiNode": {
      "requiredFields": ["type"],
      "optionalFields": [
        "id",
        "props",
        "children",
        "visibleWhen",
        "enabledWhen",
        "event",
        "items"
      ],
      "notes": [
        "Children are rendered recursively.",
        "Renderer must not invent subtree structure."
      ]
    }
  },
  "nodeTypes": {
    "layout": ["vstack", "hstack", "zstack", "scroll", "spacer"],
    "primitive": ["text", "icon", "toggle", "badge"],
    "composite": ["button", "card"]
  },
  "nodeRules": {
    "vstack": {
      "childrenAllowed": true
    },
    "hstack": {
      "childrenAllowed": true
    },
    "zstack": {
      "childrenAllowed": true
    },
    "scroll": {
      "childrenAllowed": true
    },
    "spacer": {
      "childrenAllowed": false
    },
    "text": {
      "childrenAllowed": false,
      "requiredProps": ["value"]
    },
    "icon": {
      "childrenAllowed": false,
      "requiredProps": ["name"],
      "optionalProps": ["size"]
    },
    "toggle": {
      "childrenAllowed": false,
      "requiredProps": ["title", "bind"]
    },
    "badge": {
      "childrenAllowed": false
    },
    "button": {
      "childrenAllowed": true,
      "childrenRecommended": true,
      "requiredEventKeys": ["tap"],
      "notes": [
        "Button is a composite node.",
        "Button label must be authored through children in base mode.",
        "Renderer must not auto-create text or icon subtree from props."
      ]
    },
    "card": {
      "childrenAllowed": true
    }
  },
  "props": {
    "common": [
      "padding",
      "width",
      "height",
      "minWidth",
      "minHeight",
      "maxWidth",
      "maxHeight",
      "backgroundColor",
      "foregroundColor",
      "cornerRadius",
      "opacity"
    ],
    "layout": ["spacing", "alignment"],
    "text": ["value"],
    "icon": ["name", "size"],
    "toggle": ["title", "bind"]
  },
  "strictFormats": {
    "nodeEventFormat": {
      "description": "Node event values must be string event names.",
      "valid": {
        "event": {
          "tap": "searchPressed"
        }
      },
      "invalid": [
        {
          "event": {
            "tap": [
              {
                "do": "state.set",
                "key": "statusText",
                "value": "Search pressed"
              }
            ]
          }
        }
      ]
    },
    "topLevelEventsFormat": {
      "description": "All actions live in top-level events map.",
      "valid": {
        "events": {
          "searchPressed": [
            {
              "do": "state.set",
              "key": "statusText",
              "value": "Search pressed"
            }
          ]
        }
      }
    },
    "actionFormat": {
      "requiredFields": ["do"],
      "optionalFields": ["key", "value", "min", "max", "id", "input", "message"],
      "disallowedAliases": ["action", "target"]
    },
    "textValueFormat": {
      "allowedForms": [
        { "value": "Literal text" },
        { "value": { "bind": "selectedField" } },
        { "value": { "format": "Count: {count}", "binds": ["count"] } }
      ],
      "disallowedForms": [
        { "value": "$state.selectedField" }
      ]
    }
  },
  "actions": {
    "supported": [
      "state.set",
      "state.inc",
      "state.dec",
      "state.toggle",
      "ui.toast",
      "ai.request"
    ]
  },
  "expressions": {
    "supportedContexts": ["visibleWhen", "enabledWhen"]
  },
  "baseModeConstraints": {
    "disallowedNodeTypes": ["frame", "box", "columns", "toolbar"],
    "notes": [
      "Do not generate these node types for base runtime documents."
    ]
  },
  "ownershipBoundaries": {
    "appOwns": [
      "shell",
      "safe area handling",
      "device-aware layout policy",
      "top and bottom overlay policy",
      "screen bounds awareness"
    ],
    "jsonOwns": [
      "content tree",
      "local node composition",
      "local props",
      "state bindings",
      "event wiring",
      "section structure"
    ]
  },
  "generationRules": [
    "Use only supported node types.",
    "Use button as composite node with children.",
    "Do not inline actions inside node.event.",
    "Do not invent aliases for action fields.",
    "Do not use unsupported dynamic text syntaxes.",
    "Prefer native stack composition.",
    "Prefer local props over artificial wrapper nodes.",
    "Do not generate deprecated or experimental layout abstractions in base mode."
  ],
  "knownProjectFacts": {
    "layoutSupportUsed": false,
    "documentValidatorActive": false,
    "buttonCompositeModeActive": true
  }
}

Examples:
{
  "schema": "uibuilder.base.v1",
  "screenId": "example-button-composite",
  "root": {
    "type": "vstack",
    "id": "rootStack",
    "props": {
      "spacing": 12,
      "padding": 16,
      "maxWidth": "infinity"
    },
    "children": [
      {
        "type": "button",
        "id": "homeButton",
        "props": {
          "padding": 12,
          "backgroundColor": "#EEF2FF",
          "foregroundColor": "#2563EB",
          "cornerRadius": 12,
          "maxWidth": "infinity"
        },
        "event": {
          "tap": "homePressed"
        },
        "children": [
          {
            "type": "hstack",
            "id": "homeButtonLabel",
            "props": {
              "spacing": 8,
              "alignment": "center",
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "icon",
                "id": "homeButtonIcon",
                "props": {
                  "name": "house.fill",
                  "size": 18
                }
              },
              {
                "type": "text",
                "id": "homeButtonText",
                "props": {
                  "value": "Home"
                }
              },
              {
                "type": "spacer",
                "id": "homeButtonSpacer"
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "homePressed": [
      {
        "do": "ui.toast",
        "message": "Home pressed"
      }
    ]
  }
}

{
  "schema": "uibuilder.base.v1",
  "screenId": "example-settings-row",
  "root": {
    "type": "vstack",
    "id": "rootStack",
    "props": {
      "spacing": 0,
      "padding": 16,
      "maxWidth": "infinity",
      "backgroundColor": "#FFFFFF",
      "cornerRadius": 16
    },
    "children": [
      {
        "type": "button",
        "id": "privacyRow",
        "props": {
          "padding": 14,
          "foregroundColor": "#111111",
          "maxWidth": "infinity"
        },
        "event": {
          "tap": "privacyPressed"
        },
        "children": [
          {
            "type": "hstack",
            "id": "privacyRowContent",
            "props": {
              "spacing": 12,
              "alignment": "center",
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "icon",
                "id": "privacyRowIcon",
                "props": {
                  "name": "lock",
                  "size": 18
                }
              },
              {
                "type": "text",
                "id": "privacyRowText",
                "props": {
                  "value": "Конфиденциальность"
                }
              },
              {
                "type": "spacer",
                "id": "privacyRowSpacer"
              },
              {
                "type": "icon",
                "id": "privacyRowChevron",
                "props": {
                  "name": "chevron.right",
                  "size": 14,
                  "foregroundColor": "#C7C7CC"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "privacyPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Privacy selected"
      }
    ]
  }
}

{
  "schema": "uibuilder.base.v1",
  "screenId": "example-small-screen",
  "title": "Controls",
  "state": {
    "vars": {
      "selectedField": "Ничего не выбрано",
      "wifiEnabled": false
    }
  },
  "root": {
    "type": "scroll",
    "id": "rootScroll",
    "children": [
      {
        "type": "vstack",
        "id": "rootStack",
        "props": {
          "spacing": 16,
          "padding": 16,
          "maxWidth": "infinity"
        },
        "children": [
          {
            "type": "hstack",
            "id": "topButtons",
            "props": {
              "spacing": 12,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "button",
                "id": "homeButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "homePressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "homeIcon",
                    "props": {
                      "name": "house",
                      "size": 18
                    }
                  }
                ]
              },
              {
                "type": "button",
                "id": "searchButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "searchPressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "searchIcon",
                    "props": {
                      "name": "magnifyingglass",
                      "size": 18
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "hstack",
            "id": "wifiRow",
            "props": {
              "spacing": 12,
              "padding": 12,
              "backgroundColor": "#FFFFFF",
              "cornerRadius": 12,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "button",
                "id": "wifiRowButton",
                "props": {
                  "maxWidth": "infinity"
                },
                "event": {
                  "tap": "wifiPressed"
                },
                "children": [
                  {
                    "type": "hstack",
                    "id": "wifiRowLabel",
                    "props": {
                      "maxWidth": "infinity"
                    },
                    "children": [
                      {
                        "type": "text",
                        "id": "wifiRowText",
                        "props": {
                          "value": "Wi-Fi"
                        }
                      },
                      {
                        "type": "spacer",
                        "id": "wifiRowSpacer"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "toggle",
                "id": "wifiToggle",
                "props": {
                  "title": "",
                  "bind": "wifiEnabled"
                },
                "event": {
                  "change": "wifiChanged"
                }
              }
            ]
          },
          {
            "type": "card",
            "id": "bottomCard",
            "props": {
              "padding": 16,
              "backgroundColor": "#F2F2F7",
              "cornerRadius": 16,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "vstack",
                "id": "bottomCardStack",
                "props": {
                  "spacing": 8,
                  "alignment": "leading",
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "text",
                    "id": "bottomCardTitle",
                    "props": {
                      "value": "Поле внизу"
                    }
                  },
                  {
                    "type": "text",
                    "id": "bottomCardValue",
                    "props": {
                      "value": {
                        "bind": "selectedField"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "homePressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Home pressed"
      }
    ],
    "searchPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Search pressed"
      }
    ],
    "wifiPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Wi-Fi row selected"
      }
    ],
    "wifiChanged": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Wi-Fi changed"
      }
    ]
  },
  "meta": {
    "examplePurpose": "small canonical screen",
    "rulesShown": [
      "button as composite",
      "row composition",
      "toggle row",
      "top-level events map",
      "bind-based text value"
    ]
  }
}

