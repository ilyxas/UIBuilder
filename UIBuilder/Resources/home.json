{
  "schema": "com.ilya.ui/1.0",
  "screenId": "controls-selection-screen",
  "title": "Controls",
  "state": {
    "vars": {
      "selectedField": "Ничего не выбрано",
      "wifiEnabled": false,
      "bluetoothEnabled": true,
      "notificationsEnabled": false,
      "locationEnabled": true
    }
  },
  "root": {
    "type": "scroll",
    "id": "rootScroll",
    "children": [
      {
        "type": "vstack",
        "id": "rootStack",
        "props": {
          "spacing": 16,
          "padding": 16,
          "maxWidth": "infinity"
        },
        "children": [
          {
            "type": "hstack",
            "id": "topIconButtons",
            "props": {
              "spacing": 12,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "button",
                "id": "homeButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "homePressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "homeIcon",
                    "props": {
                      "name": "house",
                      "size": 18
                    }
                  }
                ]
              },
              {
                "type": "button",
                "id": "searchButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "searchPressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "searchIcon",
                    "props": {
                      "name": "magnifyingglass",
                      "size": 18
                    }
                  }
                ]
              },
              {
                "type": "button",
                "id": "bellButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "bellPressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "bellIcon",
                    "props": {
                      "name": "bell",
                      "size": 18
                    }
                  }
                ]
              },
              {
                "type": "button",
                "id": "gearButton",
                "props": {
                  "padding": 12,
                  "backgroundColor": "#F2F2F7",
                  "cornerRadius": 12
                },
                "event": {
                  "tap": "gearPressed"
                },
                "children": [
                  {
                    "type": "icon",
                    "id": "gearIcon",
                    "props": {
                      "name": "gearshape",
                      "size": 18
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "vstack",
            "id": "settingsRows",
            "props": {
              "spacing": 12,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "hstack",
                "id": "wifiRow",
                "props": {
                  "spacing": 12,
                  "padding": 12,
                  "backgroundColor": "#FFFFFF",
                  "cornerRadius": 12,
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "button",
                    "id": "wifiRowButton",
                    "props": {
                      "maxWidth": "infinity",
                      "foregroundColor": "#111111"
                    },
                    "event": {
                      "tap": "wifiRowPressed"
                    },
                    "children": [
                      {
                        "type": "hstack",
                        "id": "wifiRowLabel",
                        "props": {
                          "spacing": 8,
                          "alignment": "center",
                          "maxWidth": "infinity"
                        },
                        "children": [
                          {
                            "type": "text",
                            "id": "wifiRowText",
                            "props": {
                              "value": "Wi-Fi"
                            }
                          },
                          {
                            "type": "spacer",
                            "id": "wifiRowSpacer"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "toggle",
                    "id": "wifiToggle",
                    "props": {
                      "title": "",
                      "bind": "wifiEnabled"
                    },
                    "event": {
                      "change": "wifiChanged"
                    }
                  }
                ]
              },
              {
                "type": "hstack",
                "id": "bluetoothRow",
                "props": {
                  "spacing": 12,
                  "padding": 12,
                  "backgroundColor": "#FFFFFF",
                  "cornerRadius": 12,
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "button",
                    "id": "bluetoothRowButton",
                    "props": {
                      "maxWidth": "infinity",
                      "foregroundColor": "#111111"
                    },
                    "event": {
                      "tap": "bluetoothRowPressed"
                    },
                    "children": [
                      {
                        "type": "hstack",
                        "id": "bluetoothRowLabel",
                        "props": {
                          "spacing": 8,
                          "alignment": "center",
                          "maxWidth": "infinity"
                        },
                        "children": [
                          {
                            "type": "text",
                            "id": "bluetoothRowText",
                            "props": {
                              "value": "Bluetooth"
                            }
                          },
                          {
                            "type": "spacer",
                            "id": "bluetoothRowSpacer"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "toggle",
                    "id": "bluetoothToggle",
                    "props": {
                      "title": "",
                      "bind": "bluetoothEnabled"
                    },
                    "event": {
                      "change": "bluetoothChanged"
                    }
                  }
                ]
              },
              {
                "type": "hstack",
                "id": "notificationsRow",
                "props": {
                  "spacing": 12,
                  "padding": 12,
                  "backgroundColor": "#FFFFFF",
                  "cornerRadius": 12,
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "button",
                    "id": "notificationsRowButton",
                    "props": {
                      "maxWidth": "infinity",
                      "foregroundColor": "#111111"
                    },
                    "event": {
                      "tap": "notificationsRowPressed"
                    },
                    "children": [
                      {
                        "type": "hstack",
                        "id": "notificationsRowLabel",
                        "props": {
                          "spacing": 8,
                          "alignment": "center",
                          "maxWidth": "infinity"
                        },
                        "children": [
                          {
                            "type": "text",
                            "id": "notificationsRowText",
                            "props": {
                              "value": "Уведомления"
                            }
                          },
                          {
                            "type": "spacer",
                            "id": "notificationsRowSpacer"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "toggle",
                    "id": "notificationsToggle",
                    "props": {
                      "title": "",
                      "bind": "notificationsEnabled"
                    },
                    "event": {
                      "change": "notificationsChanged"
                    }
                  }
                ]
              },
              {
                "type": "hstack",
                "id": "locationRow",
                "props": {
                  "spacing": 12,
                  "padding": 12,
                  "backgroundColor": "#FFFFFF",
                  "cornerRadius": 12,
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "button",
                    "id": "locationRowButton",
                    "props": {
                      "maxWidth": "infinity",
                      "foregroundColor": "#111111"
                    },
                    "event": {
                      "tap": "locationRowPressed"
                    },
                    "children": [
                      {
                        "type": "hstack",
                        "id": "locationRowLabel",
                        "props": {
                          "spacing": 8,
                          "alignment": "center",
                          "maxWidth": "infinity"
                        },
                        "children": [
                          {
                            "type": "text",
                            "id": "locationRowText",
                            "props": {
                              "value": "Геолокация"
                            }
                          },
                          {
                            "type": "spacer",
                            "id": "locationRowSpacer"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "toggle",
                    "id": "locationToggle",
                    "props": {
                      "title": "",
                      "bind": "locationEnabled"
                    },
                    "event": {
                      "change": "locationChanged"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "card",
            "id": "selectedFieldCard",
            "props": {
              "padding": 16,
              "backgroundColor": "#F2F2F7",
              "cornerRadius": 16,
              "maxWidth": "infinity"
            },
            "children": [
              {
                "type": "vstack",
                "id": "selectedFieldCardStack",
                "props": {
                  "spacing": 8,
                  "alignment": "leading",
                  "maxWidth": "infinity"
                },
                "children": [
                  {
                    "type": "text",
                    "id": "selectedFieldTitle",
                    "props": {
                      "value": "Выбранное поле"
                    }
                  },
                  {
                    "type": "text",
                    "id": "selectedFieldValue",
                    "props": {
                      "value": {
                        "bind": "selectedField"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "events": {
    "homePressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Нажата кнопка Home"
      }
    ],
    "searchPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Нажата кнопка Search"
      }
    ],
    "bellPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Нажата кнопка Bell"
      }
    ],
    "gearPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Нажата кнопка Settings"
      }
    ],
    "wifiRowPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Выбрано поле Wi-Fi"
      }
    ],
    "wifiChanged": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Изменен toggle Wi-Fi"
      }
    ],
    "bluetoothRowPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Выбрано поле Bluetooth"
      }
    ],
    "bluetoothChanged": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Изменен toggle Bluetooth"
      }
    ],
    "notificationsRowPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Выбрано поле Уведомления"
      }
    ],
    "notificationsChanged": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Изменен toggle Уведомления"
      }
    ],
    "locationRowPressed": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Выбрано поле Геолокация"
      }
    ],
    "locationChanged": [
      {
        "do": "state.set",
        "key": "selectedField",
        "value": "Изменен toggle Геолокация"
      }
    ]
  }
}
